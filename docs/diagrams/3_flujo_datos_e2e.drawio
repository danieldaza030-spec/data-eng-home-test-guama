        <!-- 2. Data Ingest Pipeline -->
        <mxCell id="ingest" value="&lt;b&gt;Data Ingest Pipeline&lt;/b&gt;&lt;br&gt;download_iris_data&lt;br&gt;↓ validate_iris_data&lt;br&gt;↓ transform_iris_data"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;arcSize=8;"
