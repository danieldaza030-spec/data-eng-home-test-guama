          vertex="1" parent="1">
          <mxGeometry x="1020" y="210" width="170" height="90" as="geometry" />
        </mxCell>

        <!-- 6. FastAPI -->
        <mxCell id="fastapi" value="&lt;b&gt;FastAPI&lt;/b&gt;&lt;br&gt;POST /predict&lt;br&gt;GET /info&lt;br&gt;&lt;font color='#888'&gt;:8000&lt;/font&gt;"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;arcSize=8;"
          vertex="1" parent="1">
          <mxGeometry x="1265" y="210" width="155" height="90" as="geometry" />
        </mxCell>

        <!-- 7. Prediction Store -->
        <mxCell id="pred_store" value="&lt;b&gt;Prediction Store&lt;/b&gt;&lt;br&gt;predicted.csv&lt;br&gt;&lt;font color='#888'&gt;/public/prediction_storage/&lt;br&gt;col: prediction_at (UTC)&lt;/font&gt;"
          style="shape=cylinder3;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;"
          vertex="1" parent="1">
          <mxGeometry x="1485" y="205" width="155" height="100" as="geometry" />
        </mxCell>

        <!-- ================================================================
             FILA INFERIOR — generate_synthetic_data + Drift Monitor
             ================================================================ -->

        <!-- generate_synthetic_data DAG (sobre la prediction store) -->
        <mxCell id="gen_data" value="&lt;b&gt;generate_synthetic_data&lt;/b&gt;&lt;br&gt;mode: normal | drifted | dirty&lt;br&gt;&lt;font color='#888'&gt;genera tráfico de producción simulado&lt;/font&gt;"
