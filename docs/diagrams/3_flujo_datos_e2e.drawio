        <!-- 3. Feature Store -->
        <mxCell id="feature_store" value="&lt;b&gt;Feature Store&lt;/b&gt;&lt;br&gt;features_iris.csv&lt;br&gt;&lt;font color='#888'&gt;/public/feature_storage/&lt;br&gt;col: processed_at (UTC)&lt;/font&gt;"
          style="shape=cylinder3;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;"
          vertex="1" parent="1">
          <mxGeometry x="530" y="205" width="170" height="100" as="geometry" />
        </mxCell>

        <!-- 4. Training Pipeline -->
        <mxCell id="training" value="&lt;b&gt;Training Pipeline&lt;/b&gt;&lt;br&gt;SVM | LR | KNN&lt;br&gt;GridSearchCV + StandardScaler&lt;br&gt;MLflow run logging"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;arcSize=8;"
          vertex="1" parent="1">
          <mxGeometry x="775" y="210" width="175" height="90" as="geometry" />
        </mxCell>

        <!-- 5. MLflow Registry -->
        <mxCell id="mlflow_reg" value="&lt;b&gt;MLflow Registry&lt;/b&gt;&lt;br&gt;iris_classifier&lt;br&gt;@champion&lt;br&gt;&lt;font color='#888'&gt;tag: training_dates&lt;/font&gt;"
