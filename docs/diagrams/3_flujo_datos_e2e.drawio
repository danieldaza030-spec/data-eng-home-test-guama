        </mxCell>

        <!-- 8. Drift Monitor -->
        <mxCell id="drift_mon" value="&lt;b&gt;Drift Monitor&lt;/b&gt;&lt;br&gt;KS test (alpha=0.05)&lt;br&gt;feature_store vs predicted.csv&lt;br&gt;&lt;font color='#888'&gt;@daily | min 30 filas&lt;/font&gt;"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;arcSize=8;"
          vertex="1" parent="1">
          <mxGeometry x="1265" y="430" width="200" height="90" as="geometry" />
        </mxCell>

        <!-- Streamlit Dashboard (junto al drift monitor) -->
        <mxCell id="streamlit" value="&lt;b&gt;Streamlit Dashboard&lt;/b&gt;&lt;br&gt;:8501&lt;br&gt;&lt;font color='#888'&gt;histogramas + KS table&lt;br&gt;botón retraining manual&lt;/font&gt;"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;arcSize=8;"
          vertex="1" parent="1">
          <mxGeometry x="1485" y="430" width="200" height="90" as="geometry" />
        </mxCell>

        <!-- ================================================================
             EDGES — pipeline principal
             ================================================================ -->

        <!-- src → ingest -->
        <mxCell id="ef1" value="CSV raw"
          style="edgeStyle=orthogonalEdgeStyle;fontSize=10;"
          edge="1" source="src" target="ingest" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- ingest → feature_store -->
        <mxCell id="ef2" value="features + processed_at"
          style="edgeStyle=orthogonalEdgeStyle;fontSize=10;"
          edge="1" source="ingest" target="feature_store" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- feature_store → training -->
        <mxCell id="ef3" value="training data"
          style="edgeStyle=orthogonalEdgeStyle;fontSize=10;"
          edge="1" source="feature_store" target="training" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- training → mlflow_reg -->
        <mxCell id="ef4" value="register best model&lt;br&gt;(f1_macro)"
          style="edgeStyle=orthogonalEdgeStyle;fontSize=10;"
          edge="1" source="training" target="mlflow_reg" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- mlflow_reg → fastapi -->
        <mxCell id="ef5" value="load @champion&lt;br&gt;(hot-reload)"
          style="edgeStyle=orthogonalEdgeStyle;fontSize=10;"
          edge="1" source="mlflow_reg" target="fastapi" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- fastapi → pred_store -->
        <mxCell id="ef6" value="log prediction"
          style="edgeStyle=orthogonalEdgeStyle;fontSize=10;"
          edge="1" source="fastapi" target="pred_store" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- ================================================================
             EDGES — drift monitoring loop
             ================================================================ -->

        <!-- pred_store → drift_mon -->
        <mxCell id="ef7" value="predicted.csv"
          style="edgeStyle=orthogonalEdgeStyle;fontSize=10;"
          edge="1" source="pred_store" target="drift_mon" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- feature_store → drift_mon (referencia de entrenamiento) -->
        <mxCell id="ef8" value="training reference&lt;br&gt;(filtrado por training_dates)"
          style="edgeStyle=orthogonalEdgeStyle;fontSize=10;dashed=1;endArrow=open;"
          edge="1" source="feature_store" target="drift_mon" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="615" y="570" />
              <mxPoint x="1265" y="570" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- drift_mon → training (trigger retraining) -->
        <mxCell id="ef9" value="trigger retraining&lt;br&gt;(p &lt; 0.05 en alguna feature)"
          style="edgeStyle=orthogonalEdgeStyle;fontSize=10;strokeColor=#b85450;fontColor=#b85450;fontStyle=1;dashed=1;"
          edge="1" source="drift_mon" target="training" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="1265" y="480" />
              <mxPoint x="862" y="480" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- gen_data → pred_store (simulated traffic) -->
        <mxCell id="ef10" value="POST /predict&lt;br&gt;(filas válidas)"
